  m_Script: {fileID: 11500000, guid: ac27a74fc19b4408accc9281885acf8c, type: 3}
  m_Name: LuminshroomText
  m_EditorClassIdentifier: 
  text: '1. Enchant raw luminshroom (Warning: overenchanting raw luminshroom will
    cause it to become unstable)

    2. Seal enchanted luminshroom (Warning: enchanted
    luminshroom is extremely volatile and should not be left out for more than a
    few seconds)

    3. Add enchanted sealed luminshroom to the pot'
