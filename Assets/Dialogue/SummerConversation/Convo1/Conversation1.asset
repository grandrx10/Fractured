  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 470f427762ba79142a63a00a4c49293c, type: 3}
  m_Name: Conversation1
  m_EditorClassIdentifier: 
  inChat: 1
  dialogues:
  - speakerName: Ravenna
    line: Dori! Dori, Dori! Hey, don't ignore me when I'm talking to you!
    voiceLine: {fileID: 8300000, guid: 46e5069fe25e1e24a8e61e614c8e9513, type: 3}
    events: []
  - speakerName: Dorian
    line: What is it, Ravi? It's my one day off, you know?
    voiceLine: {fileID: 8300000, guid: a9293528911e43b4d980181b39a884f5, type: 3}
    events: []
  - speakerName: Ravenna
    line: A friend of mine promised he would go exploring with me today, and I think
      he forgot all about it. Instead, he's relaxing on the beach, getting a tan!
      Ahem, ahem.
    voiceLine: {fileID: 8300000, guid: 18a377dea34a53746b4f3e17fbe03d48, type: 3}
    events: []
  - speakerName: Dorian
    line: Ah, I did say something like that, didn't I? Am I in trouble?
    voiceLine: {fileID: 8300000, guid: 6f0581ba8681e77468e84c848152fa11, type: 3}
    events: []
  - speakerName: Ravenna
    line: Not if you come along right now.
    voiceLine: {fileID: 8300000, guid: 942f87b0d41d2e24bafc4d6a0eeb5719, type: 3}
    events: []
  - speakerName: Dorian
    line: Alright, fine, fine. I'm getting up.
    voiceLine: {fileID: 8300000, guid: 3445ca42ba32dfb4c86294a9e2510644, type: 3}
    events: []
